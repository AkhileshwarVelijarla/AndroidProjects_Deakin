<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background color - Pure Black -->
    <solid android:color="#000000"/>

    <!-- Border - Cyan Accent -->
    <stroke
        android:width="2dp"
        android:color="#00E5FF"/>

    <!-- Rounded corners -->
    <corners android:radius="8dp"/>

    <!-- Padding inside -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="8dp"
        android:bottom="8dp"/>
</shape>