<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Results"
            android:textAppearance="@style/Widget.LearningAssistant.ScreenTitle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Assessed by AI"
            android:textColor="@color/accent_yellow_dark"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/resultsScoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textAppearance="@style/Widget.LearningAssistant.SectionTitle" />

        <LinearLayout
            android:id="@+id/resultsFeedbackContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Follow-up"
                    android:textAppearance="@style/Widget.LearningAssistant.SectionTitle" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/resultsSimulateFailureCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Simulate API failure"
                    android:textColor="@color/text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/resultsStudyPlanButton"
                    style="@style/Widget.LearningAssistant.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Create 7-Day Study Plan" />

                <ProgressBar
                    android:id="@+id/resultsLlmLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/resultsPromptText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_ai_box"
                    android:padding="12dp"
                    android:text="Prompt will appear here."
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/resultsResponseText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_ai_box"
                    android:padding="12dp"
                    android:text="Response will appear here."
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/resultsErrorText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/error_red"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/resultsRetryButton"
                    style="@style/Widget.LearningAssistant.SecondaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Retry"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/resultsContinueButton"
                    style="@style/Widget.LearningAssistant.SecondaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Continue" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
